# DeepSeno Android — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# For GitHub Actions, set these as repository secrets.

# === Signing (Release Builds) ===
# Generate a keystore: keytool -genkey -v -keystore deepseno-release.jks -alias deepseno -keyalg RSA -keysize 2048 -validity 10000
# Base64 encode: base64 -i deepseno-release.jks | tr -d '\n'
SIGNING_KEYSTORE_BASE64=your_base64_encoded_keystore_here
SIGNING_STORE_PASSWORD=your_store_password_here
SIGNING_KEY_ALIAS=your_key_alias_here
SIGNING_KEY_PASSWORD=your_key_password_here

# === Relay Server (aligned with iOS project) ===
RELAY_SERVER_BASE_URL=https://your-server.example.com/api/v1

# === Release Server (GitHub Actions only, not needed locally) ===
# RELEASE_ADMIN_EMAIL=admin@example.com
# RELEASE_ADMIN_PASSWORD=your_admin_password
